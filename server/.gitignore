
# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.npm/

# ── Lockfiles (keep package-lock.json, ignore others) ────────────────────────
yarn.lock
pnpm-lock.yaml

# ── Environment — NEVER commit real secrets ───────────────────────────────────
.env
.env.local
.env.*.local
# .env.example IS committed on purpose (safe template with no real values)

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

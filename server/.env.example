# Server environment variables
# Copy this file to .env and fill in real values.
# Never commit the real .env file — it contains secrets.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
# Local MongoDB (default for development)
MONGO_URI=mongodb://localhost:27017/menubaran

# Cloud MongoDB Atlas (use this for staging / production)
# MONGO_URI=mongodb+srv://saktibyte_demo:saktibyte_demo_password@demosaktibyte.o5tv2qr.mongodb.net/menubaran
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/menubaran

# ── JWT Secrets — generate strong random strings for production ───────────────
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret

# ── Admin Seed Credentials ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@menubaran.com
ADMIN_PASSWORD=change-this-password

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production domain(s) only — all localhost ports are allowed automatically.
# For multiple domains separate with commas (no spaces):
# FRONTEND_URL=https://menubaran.vercel.app,https://menubaran.com
FRONTEND_URL=http://localhost:3000,http://localhost:4173

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ── Site URL (used in emails / links) ─────────────────────────────────────────
SITE_URL=http://localhost:5000
